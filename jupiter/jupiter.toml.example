# 5thPlanet frontend configuration — example / reference template
#
# Copy this file to the live config location and edit to taste. The frontend
# looks for the config **portable-first**:
#
#   1. a `jupiter.toml` right next to the `jupiter` executable — the portable /
#      self-contained-archive location; if present it wins, overriding any
#      global config, so the config travels with the binary.
#   2. $XDG_CONFIG_HOME/5thplanet/jupiter.toml
#      (fallback: ~/.config/5thplanet/jupiter.toml)
#
# Whichever file is chosen is also the one written back to. A fresh install with
# no config yet writes the portable file when the exe location is known, else
# the XDG path.
#
# The frontend writes this file itself whenever you change a setting in the
# in-window OSD (Esc -> Settings), so hand-editing is optional. It is a tiny,
# dependency-free TOML *subset*: flat `key = value` lines only — strings are
# quoted, integers and booleans are bare, and `#` starts a comment. Nested
# tables and arrays are NOT parsed. The reader is tolerant: unknown keys,
# blank lines and malformed lines are skipped, and any missing key keeps its
# built-in default, so an old or partial file never blocks boot.
#
# Precedence for every setting: a command-line flag beats this file, which
# beats the built-in default (for `region`, the BIOS-filename autodetect).

# --- Graphics ---------------------------------------------------------------

# Window scale: integer 1..=4, multiplying the 320x224 base. Out-of-range
# values are clamped into [1, 4]. Default: 2.
scale = 2

# Start in fullscreen. Default: false.
fullscreen = false

# Graphics-presentation backend = which SDL2 render driver blits the frame.
# Same vocabulary as the `--backend=` CLI flag. The emulator's picture is always
# rendered in software (for accuracy); this only selects how that finished 2D
# frame is presented, with an automatic fallback chain (preferred -> opengl ->
# software). Valid values:
#   "auto"        let SDL2 pick its platform default (default)
#   "opengl"   "opengles"   "metal"
#   "direct3d11"  "direct3d12"  "software"
# Note: "vulkan" is NOT available in SDL2's 2D renderer; it maps to "auto".
backend = "auto"

# SDL_GPU capability probe, same vocabulary as the `--gpu` CLI flag. Groundwork
# for the planned CRT-shader presenter (the GPU is presentation-only — ADR-0019);
# the probe only logs whether this host could create an SDL_GPU device. **Only
# active in `gpu-preview` builds** (`cargo build --features gpu-preview`); in a
# normal build this key + the `--gpu` flag are inert. Valid values:
#   "off"   never probe (default; the SDL_Renderer blit is the only path)
#   "auto"  probe at startup and report
#   "on"    probe and warn loudly if it fails
# Default: "off".
gpu = "off"

# Texture scaling filter when the framebuffer is upscaled to the window.
# SDL3 defaults textures to linear (smooth/blurry); this restores the crisp
# SDL2-era look. Toggle it live in the OSD (Settings -> Graphics -> Pixels).
#   "sharp"   nearest-neighbour, crisp pixel dots (default)
#   "smooth"  bilinear filtering (softer)
# Default: "sharp".
scaling = "sharp"

# Aspect handling (via SDL3 logical presentation), applied in both windowed and
# fullscreen modes. The Saturn picture is 4:3 with non-square pixels, so its raw
# framebuffer ratio (e.g. 640x224) is NOT the display ratio. Toggle it live in
# the OSD (Settings -> Graphics -> Aspect).
#   "keep"     keep the 4:3 display aspect, letterboxed (default)
#   "stretch"  fit to the window/screen, filling it (distorts the 4:3 picture)
# Default: "keep".
aspect = "keep"

# --- System -----------------------------------------------------------------

# SMPC region token. Omit this key entirely to autodetect from the BIOS
# filename (the default). Valid values:
#   "japan"          "north-america"
#   "europe-pal"     "asia-ntsc"
# region = "japan"

# Rear expansion cartridge, same vocabulary as the `--cart=` CLI flag:
#   "none"   empty slot
#   "ram1m"  1 MiB Extension RAM
#   "ram4m"  4 MiB Extension RAM
#   "bram"   battery-backed RAM cart
# Default: "none".
cartridge = "none"

# Shuttle Mouse, same vocabulary as the `--mouse[=1|2]` CLI flag:
#   "off"  no mouse (default)
#   "1"    mouse on port 1, replacing the keyboard pad
#   "2"    mouse on port 2, keyboard pad stays on port 1
# The host mouse drives it (motion + clicks; Return = the mouse Start button;
# F10 toggles pointer capture). Default: "off".
mouse = "off"

# --- Keyboard bindings ------------------------------------------------------
#
# Each Saturn digital-pad button is bound to one SDL *scancode name* (a
# string; resolved via SDL_Scancode::from_name at the edge). The defaults
# below are: arrows = D-pad, Z/X/C = A/B/C, A/S/D = X/Y/Z, Q/W = L/R,
# Return = Start. Rebind interactively via OSD -> Settings -> Controller,
# or edit the names here. Find scancode names in the SDL documentation.

key_up    = "Up"
key_down  = "Down"
key_left  = "Left"
key_right = "Right"
key_a     = "Z"
key_b     = "X"
key_c     = "C"
key_x     = "A"
key_y     = "S"
key_z     = "D"
key_l     = "Q"
key_r     = "W"
key_start = "Return"
