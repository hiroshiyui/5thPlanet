# 5thPlanet frontend configuration — example / reference template
#
# Copy this file to the live config location and edit to taste. The frontend
# looks for the config **portable-first**:
#
#   1. a `jupiter.toml` right next to the `jupiter` executable — the portable /
#      self-contained-archive location; if present it wins, overriding any
#      global config, so the config travels with the binary.
#   2. $XDG_CONFIG_HOME/5thplanet/jupiter.toml
#      (fallback: ~/.config/5thplanet/jupiter.toml)
#
# Whichever file is chosen is also the one written back to. A fresh install with
# no config yet writes the portable file when the exe location is known, else
# the XDG path.
#
# The frontend writes this file itself whenever you change a setting in the
# in-window OSD (Esc -> Settings), so hand-editing is optional. It is a tiny,
# dependency-free TOML *subset*: flat `key = value` lines only — strings are
# quoted, integers and booleans are bare, and `#` starts a comment. Nested
# tables and arrays are NOT parsed. The reader is tolerant: unknown keys,
# blank lines and malformed lines are skipped, and any missing key keeps its
# built-in default, so an old or partial file never blocks boot.
#
# Precedence for every setting: a command-line flag beats this file, which
# beats the built-in default (for `region`, the BIOS-filename autodetect).

# --- Graphics ---------------------------------------------------------------

# Window scale: integer 1..=4, multiplying the 320x224 base. Out-of-range
# values are clamped into [1, 4]. Default: 2.
scale = 2

# Start in fullscreen. Default: false.
fullscreen = false

# Graphics-presentation backend = which SDL2 render driver blits the frame.
# Same vocabulary as the `--backend=` CLI flag. The emulator's picture is always
# rendered in software (for accuracy); this only selects how that finished 2D
# frame is presented, with an automatic fallback chain (preferred -> opengl ->
# software). Valid values:
#   "auto"        let SDL2 pick its platform default (default)
#   "opengl"   "opengles"   "metal"
#   "direct3d11"  "direct3d12"  "software"
# Note: "vulkan" is NOT available in SDL2's 2D renderer; it maps to "auto".
backend = "auto"

# Presentation backend, same vocabulary as the `--gpu` CLI flag. Selects whether
# the finished (software-composited) frame reaches the window via an SDL_GPU
# (Vulkan/SPIR-V) device instead of the default SDL_Renderer blit. The GPU is
# presentation-only — the picture stays bit-identical (ADR-0019); this is the
# groundwork the planned CRT-shader presenter slots into. **Only active in
# `gpu-presenter` builds** (`cargo build --features gpu-presenter`); in a normal build
# this key + the `--gpu` flag are inert. Valid values:
#   "off"   present via SDL_Renderer (default)
#   "auto"  present via SDL_GPU if a device can be created, else fall back quietly
#   "on"    present via SDL_GPU; warn loudly and fall back if it can't
# Default: "off".
gpu = "off"

# Texture scaling filter when the framebuffer is upscaled to the window.
# SDL3 defaults textures to linear (smooth/blurry); this restores the crisp
# SDL2-era look. Toggle it live in the OSD (Settings -> Graphics -> Pixels).
#   "sharp"   nearest-neighbour, crisp pixel dots (default)
#   "smooth"  bilinear filtering (softer)
# Default: "sharp".
scaling = "sharp"

# Aspect handling (via SDL3 logical presentation), applied in both windowed and
# fullscreen modes. The Saturn picture is 4:3 with non-square pixels, so its raw
# framebuffer ratio (e.g. 640x224) is NOT the display ratio. Toggle it live in
# the OSD (Settings -> Graphics -> Aspect).
#   "keep"     keep the 4:3 display aspect, letterboxed (default)
#   "stretch"  fit to the window/screen, filling it (distorts the 4:3 picture)
# Default: "keep".
aspect = "keep"

# Built-in presentation shader. **Only applied by the SDL_GPU backend** (needs a
# `gpu-presenter` build with `--gpu=on|auto`); under the default SDL_Renderer blit
# it is parsed but inert. Presentation-only — the picture stays bit-identical
# (ADR-0019). Toggle live in the OSD (Settings -> Graphics -> Shaders).
#   "none"     no post-process (default)
#   "crt"      single-pass CRT: scanlines + aperture-grille mask + gamma (flat)
# Default: "none".
shader = "none"

# --- System -----------------------------------------------------------------

# SMPC region token. Omit this key entirely to autodetect from the BIOS
# filename (the default). Valid values:
#   "japan"          "north-america"
#   "europe-pal"     "asia-ntsc"
# region = "japan"

# Rear expansion cartridge, same vocabulary as the `--cart=` CLI flag:
#   "none"   empty slot
#   "ram1m"  1 MiB Extension RAM
#   "ram4m"  4 MiB Extension RAM
#   "bram"   battery-backed RAM cart
# Default: "none".
cartridge = "none"

# Active backup-RAM cartridge card (0..7): which virtual memory-card file
# (<bios>.<n>.crtbup) the "bram" cart uses. Managed from the OSD Cartridge →
# Backup RAM Cards submenu. Default: 0.
cart_card = 0

# --- Controller ports -------------------------------------------------------
#
# Each of the two SMPC controller ports is assigned an input source. Tokens:
#   "none"             nothing plugged into the port
#   "keyboard"         the host keyboard (the key bindings below)
#   "mouse"            the host mouse (Shuttle Mouse: motion + clicks; Return =
#                      the mouse Start button; F10 toggles pointer capture)
#   "gamepad:<guid>"   a specific game controller, by its stable SDL GUID
# A device drives at most one port; an unplugged "gamepad:<guid>" falls back to
# "none". Any connected controller NOT bound to a port still drives the keyboard
# port, so a single pad works out of the box. Assign these live in the OSD
# (Settings -> Controller). Default: keyboard on port 1, nothing on port 2.
# port1 = "keyboard"
# port2 = "none"
#
# Legacy: the older `mouse = "off"|"1"|"2"` key (and the `--mouse[=1|2]` CLI
# flag) still work — on load a `mouse` value is folded into port1/port2 when
# those are unset; the flag overrides the config at startup.

# --- Keyboard bindings ------------------------------------------------------
#
# Each Saturn digital-pad button is bound to one SDL *scancode name* (a
# string; resolved via SDL_Scancode::from_name at the edge). The defaults
# below are: arrows = D-pad, Z/X/C = A/B/C, A/S/D = X/Y/Z, Q/W = L/R,
# Return = Start. Rebind interactively via OSD -> Settings -> Controller,
# or edit the names here. Find scancode names in the SDL documentation.

key_up    = "Up"
key_down  = "Down"
key_left  = "Left"
key_right = "Right"
key_a     = "Z"
key_b     = "X"
key_c     = "C"
key_x     = "A"
key_y     = "S"
key_z     = "D"
key_l     = "Q"
key_r     = "W"
key_start = "Return"

# --- Game-controller bindings -----------------------------------------------
#
# Each Saturn pad button is bound to one SDL *gamepad token* — a button name
# ("a" "b" "x" "y" = South/East/West/North, "back" "guide" "start",
# "leftstick" "rightstick", "leftshoulder" "rightshoulder", "dpup" "dpdown"
# "dpleft" "dpright") or an analog trigger ("lefttrigger" "righttrigger",
# thresholded). The defaults below follow Sega's Saturn-port convention. Rebind
# interactively via OSD -> Settings -> Controller -> Gamepad, or edit here. The
# left analog stick always doubles as the D-pad. (A controller only drives a
# port when that port is assigned to it above.)

gpad_up    = "dpup"
gpad_down  = "dpdown"
gpad_left  = "dpleft"
gpad_right = "dpright"
gpad_a     = "x"
gpad_b     = "a"
gpad_c     = "b"
gpad_x     = "y"
gpad_y     = "leftshoulder"
gpad_z     = "rightshoulder"
gpad_l     = "lefttrigger"
gpad_r     = "righttrigger"
gpad_start = "start"
