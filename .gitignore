/target

# SEGA Saturn BIOS images live in bios/ and must never be committed —
# they are copyrighted by SEGA. Each developer supplies their own dump.
# Keep the directory documented via bios/README.md (whitelisted below).
bios/*
!bios/README.md

# CD-ROM disc images (CUE/BIN, CCD/IMG/SUB, ISO) live in roms/ and must
# never be committed — they are copyrighted. Each developer supplies their own.
roms/

# MAME reference runtime artifacts (the ./mameref/ oracle writes these to the
# repo root when run from here for boot-trace diffing). Never commit them.
/cfg/
/nvram/
/error.log
